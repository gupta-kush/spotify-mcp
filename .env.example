# Spotify MCP Server Configuration
# Get your credentials from https://developer.spotify.com/dashboard
#
# 1. Create a new app at the dashboard
# 2. Copy your Client ID and Client Secret below
# 3. Add http://127.0.0.1:8888/callback as a Redirect URI in your app settings

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
